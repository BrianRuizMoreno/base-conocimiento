# RAG System - Variables de Entorno
# Copiar este archivo a .env y completar los valores

# ============================================
# BASE DE DATOS (AUTOMATICA con Docker)
# ============================================
# Si usas docker-compose.yml incluido, PostgreSQL+pgvector se levanta solo.
# Solo necesitas cambiar ADMIN_PIN_HASH y SECRET_KEY abajo.
# Si usas PostgreSQL externo (Portainer), cambia esta URL:
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@postgres:5432/rag_system

# Credenciales internas de PostgreSQL (solo si modificas docker-compose.yml)
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=rag_system

# ============================================
# SEGURIDAD (REQUERIDO - CAMBIAR ESTOS DOS)
# ============================================
# Hash bcrypt del PIN de administrador
# Generar con: python3 -c "import bcrypt; print(bcrypt.hashpw(b'TU_PIN', bcrypt.gensalt()).decode())"
ADMIN_PIN_HASH=$2b$12$...

# Clave secreta para encriptacion (32+ caracteres aleatorios)
# Generar con: openssl rand -base64 32
SECRET_KEY=tu-clave-secreta-muy-larga-32-caracteres-minimo

# ============================================
# PROVEEDORES IA (OPCIONAL - se agregan desde Admin)
# ============================================
# Gemini - Gratis (OCR + Chat + Embeddings)
# Se recomienda agregar desde el panel Admin > Configuracion, no aqui.
# Si quieres precargarla: GEMINI_API_KEY=tu-api-key-de-gemini
GEMINI_API_KEY=

# OpenAI - Opcional
OPENAI_API_KEY=

# Anthropic Claude - Opcional
ANTHROPIC_API_KEY=

# Tavily - Opcional (Web Search para comparativa de mercado)
TAVILY_API_KEY=

# ============================================
# ENTORNO (No modificar)
# ============================================
ENVIRONMENT=production
DEBUG=false

# ============================================
# CORS (Cambiar cuando tengas dominio)
# ============================================
CORS_ORIGINS=http://localhost:3000

# ============================================
# ARCHIVOS
# ============================================
MAX_FILE_SIZE=524288000
UPLOAD_DIR=/app/data

# ============================================
# WHISPER (TRANSCRIPCION AUDIO/VIDEO)
# ============================================
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ============================================
# PARAMETROS POR DEFECTO DEL CHAT
# ============================================
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_P=0.6
DEFAULT_MAX_TOKENS=2048

# ============================================
# INTEGRACIONES (Opcional)
# ============================================
N8N_WEBHOOK_URL=
