# RAG System - Variables de Entorno
# Copiar este archivo a .env y completar los valores

# ============================================
# BASE DE DATOS (ya existe en tu Swarm)
# ============================================
# Tu PostgreSQL esta en la red PhysisNet, servicio se llama "postgres"
# Usuario: postgres | Password: e4f0a7582698c2064991b82c788479
DATABASE_URL=postgresql+asyncpg://postgres:e4f0a7582698c2064991b82c788479@postgres:5432/rag_system

# ============================================
# SEGURIDAD (REQUERIDO - CAMBIAR ESTOS DOS)
# ============================================
# Hash bcrypt del PIN de administrador
# Generar con: python3 -c "import bcrypt; print(bcrypt.hashpw(b'TU_PIN', bcrypt.gensalt()).decode())"
ADMIN_PIN_HASH=

# Clave secreta para encriptacion (32+ caracteres aleatorios)
# Generar con: openssl rand -base64 32
SECRET_KEY=

# ============================================
# PROVEEDORES IA (OPCIONAL - se agregan desde Admin)
# ============================================
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TAVILY_API_KEY=

# ============================================
# ENTORNO (No modificar)
# ============================================
ENVIRONMENT=production
DEBUG=false
# Formato: URL simple, comma-separated, o JSON array: ["http://localhost:3000"]
CORS_ORIGINS=http://localhost:3000
MAX_FILE_SIZE=524288000
UPLOAD_DIR=/app/data
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_P=0.6
DEFAULT_MAX_TOKENS=2048
N8N_WEBHOOK_URL=
