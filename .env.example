# RAG System - Variables de Entorno
# Copiar este archivo a .env y completar los valores

# ============================================
# BASE DE DATOS (REQUERIDO)
# ============================================
# Tu PostgreSQL existente en Hostinger/Portainer
# Formato: postgresql+asyncpg://USUARIO:PASSWORD@HOST:PUERTO/BASE
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rag_system

# ============================================
# SEGURIDAD (REQUERIDO)
# ============================================
# Hash bcrypt del PIN de administrador
# Generar con: python3 -c "import bcrypt; print(bcrypt.hashpw(b'TU_PIN', bcrypt.gensalt()).decode())"
ADMIN_PIN_HASH=$2b$12$...

# Clave secreta para encriptacion (32+ caracteres aleatorios)
# Generar con: openssl rand -base64 32
SECRET_KEY=tu-clave-secreta-muy-larga-32-caracteres-minimo

# ============================================
# PROVEEDORES IA (RECOMENDADO)
# ============================================
# Gemini - Gratis (OCR + Chat + Embeddings)
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu-api-key-de-gemini

# OpenAI - Opcional (Chat + Embeddings)
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key

# Anthropic Claude - Opcional (Chat)
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Tavily - Opcional (Web Search para comparativa de mercado)
# Obtener en: https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-key

# ============================================
# ENTORNO
# ============================================
ENVIRONMENT=production
DEBUG=false

# ============================================
# CORS
# ============================================
# Dominios permitidos para el frontend
# En produccion, usar tu dominio:
# CORS_ORIGINS=https://conocimiento.automatizaciones-physis.cloud
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# ARCHIVOS
# ============================================
# Tamano maximo de archivo (500MB = 524288000 bytes)
MAX_FILE_SIZE=524288000
UPLOAD_DIR=/app/data

# ============================================
# WHISPER (TRANSCRIPCION AUDIO/VIDEO)
# ============================================
# Modelo: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ============================================
# PARAMETROS POR DEFECTO DEL CHAT
# ============================================
# Temperature: 0.0 = determinista, 2.0 = creativo
DEFAULT_TEMPERATURE=0.2

# Top-P: 0.0 = restrictivo, 1.0 = amplio
DEFAULT_TOP_P=0.6

# Max tokens en respuesta
DEFAULT_MAX_TOKENS=2048

# ============================================
# INTEGRACIONES
# ============================================
# Webhook de n8n para notificaciones (opcional)
# N8N_WEBHOOK_URL=https://tu-n8n.com/webhook/rag-events
N8N_WEBHOOK_URL=
